import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.List;

@RestController
@RequestMapping("/api")
public class HrmsController {

    @Autowired private UserRepository userRepository;
    @Autowired private ProfileRepository profileRepository;
    @Autowired private AttendanceRepository attendanceRepository;
    @Autowired private LeaveRequestRepository leaveRepository;
    @Autowired private PayrollRepository payrollRepository;

    // ==========================================
    // 3.1 Authentication & Authorization
    // ==========================================
    
    @PostMapping("/auth/signup")
    public ResponseEntity<String> signUp(@RequestBody SignupRequest req) {
        // Users can register using Employee ID, Email, Password, and Role[span_14](start_span)[span_14](end_span)
        if (userRepository.findByEmail(req.email()).isPresent()) {
            return ResponseEntity.badRequest().body("Email already registered");
        }
        User user = new User();
        // Setup user fields here (omitted for brevity)
        userRepository.save(user);
        
        Profile profile = new Profile(); // Initialize blank profile
        // profile.setUserId(user.getId());
        profileRepository.save(profile);
        
        return ResponseEntity.ok("User registered successfully");
    }

    @PostMapping("/auth/signin")
    public ResponseEntity<String> signIn(@RequestBody SigninRequest req) {
        // Users can log in using email and password[span_15](start_span)[span_15](end_span)
        Optional<User> user = userRepository.findByEmail(req.email());
        if (user.isEmpty() || !user.get().getPassword().equals(req.password())) {
            // Incorrect credentials should display error messages[span_16](start_span)[span_16](end_span)
            return ResponseEntity.status(HttpStatus.UNAUTHORIZED).body("Incorrect email or password");
        }
        return ResponseEntity.ok("Login successful. Role: " + user.get().getRole());
    }

    // ==========================================
    // 3.4 Attendance Management
    // ==========================================

    @PostMapping("/attendance/{userId}/checkin")
    public ResponseEntity<String> checkIn(@PathVariable Long userId) {
        // Option for check-in/check-out for employee[span_17](start_span)[span_17](end_span)
        Attendance att = new Attendance();
        // att.setUserId(userId);
        // att.setCheckIn(LocalDateTime.now());
        attendanceRepository.save(att);
        return ResponseEntity.ok("Checked in successfully");
    }

    @GetMapping("/attendance/employee/{userId}")
    public List<Attendance> getMyAttendance(@PathVariable Long userId) {
        // Employees can view only their own attendance[span_18](start_span)[span_18](end_span)
        return attendanceRepository.findByUserId(userId);
    }

    @GetMapping("/attendance/admin/all")
    public List<Attendance> getAllAttendance() {
        // Admin/HR can view attendance of all employees[span_19](start_span)[span_19](end_span)
        return attendanceRepository.findAll();
    }

    // ==========================================
    // 3.5 Leave & Time-Off Management
    // ==========================================

    @PostMapping("/leave/apply/{userId}")
    public ResponseEntity<String> applyLeave(@PathVariable Long userId, @RequestBody LeaveSubmitRequest req) {
        // Employees can select leave type, choose date range, and add remarks[span_20](start_span)[span_20](end_span)
        LeaveRequest leave = new LeaveRequest();
        // set fields from req to leave
        leaveRepository.save(leave);
        return ResponseEntity.ok("Leave request submitted with status PENDING");
    }

    @PutMapping("/leave/review/{leaveId}")
    public ResponseEntity<String> reviewLeave(@PathVariable Long leaveId, @RequestBody LeaveApprovalRequest req) {
        // Admin can approve or reject requests and add comments[span_21](start_span)[span_21](end_span)
        LeaveRequest leave = leaveRepository.findById(leaveId).orElseThrow();
        leave.setStatus(req.status());
        leave.setAdminComments(req.adminComments());
        leaveRepository.save(leave);
        // Changes reflect immediately in employee records[span_22](start_span)[span_22](end_span)
        return ResponseEntity.ok("Leave request updated to " + req.status());
    }

    // ==========================================
    // 3.6 Payroll/Salary Management
    // ==========================================

    @GetMapping("/payroll/{userId}")
    public List<Payroll> getEmployeePayroll(@PathVariable Long userId) {
        // Payroll data is read-only for employees[span_23](start_span)[span_23](end_span)
        return payrollRepository.findByUserId(userId);
    }
}
